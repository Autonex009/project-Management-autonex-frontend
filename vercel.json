{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "functions": {
    "api/ssr.js": {
      "includeFiles": "dist/server/**"
    }
  },
  "rewrites": [
    { "source": "/((?!assets/|favicon).*)", "destination": "/api/ssr" }
  ]
}
